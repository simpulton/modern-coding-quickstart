{
  "name": "users-core-model",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/users/core/model/src",
  "projectType": "library",
  "tags": [
    "type:core-model",
    "subdomain:users"
  ],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "tsc --noEmit -p libs/users/core/model/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "libs/users/core/model/jest.config.cts"
      }
    }
  }
}
